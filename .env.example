# Backend Admin Credentials (Authentication handled on backend)
ADMIN_USER=admin
ADMIN_PASSWORD=password123

# Database Configuration
DATABASE_URL=sqlite:///database.db

# Backend API URL (used by Streamlit frontend to communicate with FastAPI backend)
BACKEND_API_URL=http://backend:8000


# Streamlit Configuration
STREAMLIT_SERVER_HEADLESS=true
STREAMLIT_SERVER_PORT=8501

# Cloudflare Tunnel Configuration
CLOUDFLARE_TUNNEL_TOKEN="Paste your domain or tunnel token here"
CLOUDFLARE_TUNNEL_NAME=file-upload-manager
